{
    "schemaVersion":  2,
    "sourceUrl":  "https://raw.githubusercontent.com/McVaxius/botology/refs/heads/main/botology/plugin-repository-links.json",
    "fieldGuide":  {
                       "id":  "Stable catalog id used by botology for matching and rule references.",
                       "category":  "UI group heading for the row.",
                       "displayName":  "Visible row label shown in the manager window.",
                       "matchTokens":  "Plugin names or internal names botology will match against installed/runtime plugin data.",
                       "notes":  "Long-form warning/help text shown in the (?) popup and reused in green/yellow/red rows.",
                       "description":  "Optional plugin summary for the Category / Plugin (?) popup. If omitted, botology tries repo.json data and otherwise falls back to placeholder description.",
                       "repoUrl":  "Optional repository homepage or source URL used by the Repo button.",
                       "repoJsonUrl":  "Optional concrete repo.json URL or human note shown by the [Copy] button.",
                       "repoJsonUrls":  "Optional array of multiple concrete repo.json feed URLs. Botology merges metadata across them and [Copy] copies them all.",
                       "ruleType":  "Optional built-in assessment rule. Omit it to fall back to the compiled default handling for that id.",
                       "relatedIds":  "Optional plugin ids consulted by paired/direct/bossmod rules."
                   },
    "ruleTypeGuide":  {
                          "autoduty_conflict":  "Marks the row red when AutoDuty is loaded.",
                          "paired_conflict_yellow":  "Marks the row yellow when any relatedIds entry is loaded.",
                          "paired_conflict_red":  "Marks the row red when any relatedIds entry is loaded.",
                          "direct_conflict_red":  "Marks the row red when any relatedIds entry is loaded.",
                          "rotation_conflict":  "Marks the row yellow when another rotation/bossmod rule-driven entry is loaded.",
                          "bossmod_pair":  "Marks the row red when any relatedIds bossmod rival is loaded; otherwise falls back to rotation_conflict.",
                          "loaded_warning_yellow":  "Marks the row yellow whenever the plugin itself is currently loaded."
                      },
    "plugins":  [
                    {
